public class car {
    //public static void main(String[] args) {
        int noOfWheels;
       String color;
       float maxSpeed;
       float currentFuelInLiters;
       float currentFuelOutLiters;
        public car start(){
            if (currentFuelInLiters==0){
                System.out.println("No fuel available!, can't start!!");
            } else if (currentFuelInLiters<5) {
                System.out.println("Fuel available! but have to refuel");
            }else {
                System.out.println("car is started");
            }
            return this;
        }
       public void drive(){
           currentFuelInLiters --;
           System.out.println("car is driving");

        }
        public void addFual(float fual){
            currentFuelInLiters +=fual;
        }
        public float currentFuelInLevel(){
           return currentFuelInLiters;

    }

}

